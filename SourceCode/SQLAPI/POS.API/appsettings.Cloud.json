{
  "DeploymentMode": "Cloud",
  "DatabaseProvider": "SqlServer",
  "ConnectionStrings": {
    "DbConnectionString": "Server=your-server.database.windows.net;Database=POSDb;User Id=admin;Password=***REPLACE***;TrustServerCertificate=True;Encrypt=True;"
  },
  "MultiTenancy": {
    "Enabled": true,
    "Mode": "MultiTenant",
    "TenantResolutionStrategy": "Subdomain",
    "AllowTenantSwitching": false
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:80"
      },
      "Https": {
        "Url": "https://*:443"
      }
    }
  },
  "CloudSettings": {
    "CorsOrigins": [
      "https://app.yourcompany.com",
      "https://www.yourcompany.com",
      "http://localhost:4200"
    ],
    "EnableCdn": true,
    "CdnUrl": "https://cdn.yourcompany.com",
    "EnableRateLimiting": true,
    "MaxRequestsPerMinute": 100
  },
  "JwtSettings": {
    "key": "This*Is&A!Long)Key(For%Creating@A$SymmetricKey-CHANGE-IN-PRODUCTION",
    "issuer": "https://api.yourcompany.com",
    "audience": "PTCUsers",
    "minutesToExpiration": "60"
  },
  "ImagePathSettings": {
    "ProductImages": "ProductImages",
    "NoImageFound": "no-image-found.png",
    "SupplierImages": "SupplierImages",
    "CustomerImages": "CustomerImages",
    "ArticleBannerImagePath": "ArticleImages",
    "TestimonialsImagePath": "TestimonialImages",
    "Attachments": "Attachments",
    "CompanyLogo": "CompanyLogo",
    "BrandImages": "BrandImages",
    "LanguageImages": "LanguageImages",
    "EmailAttachmentPath": "EmailAttachments"
  },
  "DocumentPath": "Documents",
  "LanguagePath": "Languages",
  "UserProfilePath": "Users",
  "DefaultUser": {
    "DefaultUserId": "1A5CF5B9-EAD8-495C-8719-2D8BE776F452"
  },
  "AesEncryptionKey": "***REPLACE-IN-PRODUCTION***",
  "Logging": {
    "IncludeScopes": false,
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  }
}
