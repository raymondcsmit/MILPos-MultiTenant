@{
    ViewData["Title"] = "Support";
}

<div class="glass-panel" style="max-width: 800px; margin: 2rem auto;">
    <h1>Support Center</h1>
    <p>Find answers to common questions or reach our support team.</p>
    
    <div class="glass-card">
        <h3>Documentation</h3>
        <p>Read our comprehensive guides and tutorials.</p>
        <a href="#" class="glass-btn">View Docs</a>
    </div>
    
    <div class="glass-card" style="margin-top: 1rem;">
        <h3>Community Forum</h3>
        <p>Join the conversation with other NexusPOS users.</p>
        <a href="#" class="glass-btn">Visit Forum</a>
    </div>

    <div class="glass-card" style="margin-top: 1rem;">
        <h3>Email Support</h3>
        <p>Priority support for Pro and Enterprise customers.</p>
        <a asp-action="Contact" class="glass-btn glass-btn-primary">Contact Support</a>
    </div>
</div>
