{
    "info": {
        "name": "POS & Inventory Automated Test Data",
        "description": "Automated Postman Collection to seed the database with test data.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:5000/api",
            "type": "string"
        },
        {
            "key": "jwt_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "tenant_id",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "0. Register Tenant (TechCorp)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/Tenants/register",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "Tenants",
                        "register"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"TechCorp POS\",\n    \"subdomain\": \"techcorp\",\n    \"adminEmail\": \"admin@techcorp.com\",\n    \"adminPassword\": \"TechCorp@2024\",\n    \"phone\": \"+1-555-0101\",\n    \"address\": \"123 TechCorp Way\"\n}"
                }
            },
            "response": []
        },
        {
            "name": "1. Login (Tenant Admin)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/authentication/login",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "authentication",
                        "login"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"userName\": \"admin@techcorp.com\",\n    \"password\": \"TechCorp@2024\"\n}"
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var jsonData = pm.response.json();",
                            "if (jsonData && jsonData.bearerToken) {",
                            "    pm.collectionVariables.set(\"jwt_token\", jsonData.bearerToken);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
